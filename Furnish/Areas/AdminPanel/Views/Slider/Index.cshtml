@using Furnish.Models
@{
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Slider Table</h4>
                <div class="table-responsive">
                    <a aap-controller="slider" asp-action="Create" class="btn btn-outline-success btn-fw mb-3">Create</a>
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th> # </th>
                                <th> Image </th>
                                <th> Name </th>
                                <th> Discount (%) </th>
                                <th> Price </th>
                                <th> Description </th>
                                <th> Settings </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (Slider slider in Model)
                            {
                                count++;
                                <tr>
                                    <td>
                                        @count
                                    </td>
                                    @if (slider.Image != null && (slider.Image.StartsWith("http://") || slider.Image.StartsWith("https://")))
                                    {
                                        <img src="@slider.Image" alt="slider image" style="width:100px; height:60px; object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <img src="~/assets/images/website-images/@slider.Image" alt="slider image" style="width:100px; height:60px; object-fit:cover;" />
                                    }
                                    <td>
                                        @slider.Name
                                    </td>
                                    <td>
                                        %@slider.Discount
                                    </td>
                                    <td>
                                        $@slider.Price
                                    </td>
                                    <td>
                                        @(slider.Description.Length > 30 ? slider.Description.Substring(0, 30) + "..." : slider.Description)
                                    </td>
                                    <td>
                                        <a asp-action="update" asp-route-id="@slider.id" class="btn btn-outline-warning btn-sm">Edit</a>
                                        <a asp-action="delete" asp-route-id="@slider.id" class="btn btn-outline-danger btn-sm">Delete</a>
                                        <a asp-action="detail" asp-route-id="@slider.id" class="btn btn-outline-info btn-sm">Detail</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>